generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  USER
  ADMIN
  OWNER
}

enum SubscriptionType {
  BASIC
  PREMIUM
}

enum AdNetwork {
  ADMOB
  UNITY
  IRONSOURCE
  APPLOVIN
  HILLTOPADS
  ADSTERRA
  PROPELLERADS
  CUSTOM
}

enum AdType {
  BANNER
  INTERSTITIAL
  REWARDED_VIDEO
  NATIVE
  POP
}

enum WithdrawalMethod {
  BKASH
  NAGAD
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum TransactionType {
  AD_REWARD
  WITHDRAWAL
  REFUND
  BONUS
  SUBSCRIPTION_FEE
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
}

enum NotificationType {
  REWARD
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED
  SUBSCRIPTION_EXPIRING
  SYSTEM
  BONUS
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id           String  @id @default(uuid())
  name         String
  email        String? @unique
  phone        String  @unique
  passwordHash String
  role         Role    @default(USER)
  avatarUrl    String?

  refreshToken   String?
  // Balance & Earnings
  balance        Decimal @default(0.00) @db.Decimal(12, 2)
  totalEarned    Decimal @default(0.00) @db.Decimal(12, 2)
  totalWithdrawn Decimal @default(0.00) @db.Decimal(12, 2)

  // Subscription
  subscriptionType SubscriptionType @default(BASIC)

  // Status
  isActive  Boolean   @default(true)
  isBanned  Boolean   @default(false)
  banReason String?
  bannedAt  DateTime?
  bannedBy  String? // Admin/Owner id who banned

  // Device
  fcmToken String? // For push notifications
  deviceId String?

  // Timestamps
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  subscriptions Subscription[]
  adWatches     AdWatch[]
  withdrawals   Withdrawal[]
  transactions  Transaction[]
  notifications Notification[]
  referrals     Referral[]     @relation("ReferredBy")
  referredUsers Referral[]     @relation("ReferredUser")
  loginHistory  LoginHistory[]

  @@map("users")
}

// ─────────────────────────────────────────
// AUTH / SESSION
// ─────────────────────────────────────────

model LoginHistory {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  deviceInfo String?
  loginAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_history")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  purpose   String // 'register', 'forgot_password', 'withdrawal'
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_verifications")
}

// ─────────────────────────────────────────
// SUBSCRIPTION
// ─────────────────────────────────────────

model SubscriptionPlan {
  id            String           @id @default(uuid())
  name          String // "Basic", "Premium"
  type          SubscriptionType @unique
  price         Decimal          @db.Decimal(10, 2)
  durationDays  Int // 30 for monthly
  dailyAdLimit  Int
  rewardPerAd   Decimal          @db.Decimal(10, 4)
  minWithdrawal Decimal          @db.Decimal(10, 2)
  features      String[] // List of features as array
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id          String             @id @default(uuid())
  userId      String
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  price       Decimal            @db.Decimal(10, 2)
  startedAt   DateTime           @default(now())
  expiresAt   DateTime
  cancelledAt DateTime?

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// ─────────────────────────────────────────
// ADS
// ─────────────────────────────────────────

model Ad {
  id              String    @id @default(uuid())
  title           String
  description     String?
  adNetwork       AdNetwork
  adType          AdType
  adUnitId        String? // AdMob unit ID, Unity placement ID etc
  rewardAmount    Decimal   @db.Decimal(10, 4) // BDT reward per view
  durationSeconds Int       @default(30) // Minimum watch time
  isActive        Boolean   @default(true)
  targetBasic     Boolean   @default(true) // Show to basic users
  targetPremium   Boolean   @default(true) // Show to premium users
  priority        Int       @default(1) // Higher = show more
  createdBy       String // Owner/Admin id
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  adWatches AdWatch[]

  @@map("ads")
}

model AdWatch {
  id           String    @id @default(uuid())
  userId       String
  adId         String
  rewardEarned Decimal   @db.Decimal(10, 4)
  adNetwork    AdNetwork
  watchedAt    DateTime  @default(now())
  ipAddress    String?
  deviceId     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ad   Ad   @relation(fields: [adId], references: [id])

  @@map("ad_watches")
}

model DailyAdLimit {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime @db.Date
  watchCount Int      @default(0)
  earned     Decimal  @default(0.00) @db.Decimal(10, 4)

  @@unique([userId, date])
  @@map("daily_ad_limits")
}

// ─────────────────────────────────────────
// WITHDRAWAL
// ─────────────────────────────────────────

model Withdrawal {
  id            String           @id @default(uuid())
  userId        String
  amount        Decimal          @db.Decimal(10, 2)
  method        WithdrawalMethod
  accountNumber String
  accountName   String?
  status        WithdrawalStatus @default(PENDING)
  adminNote     String? // Rejection reason
  processedBy   String? // Admin/Owner id
  requestedAt   DateTime         @default(now())
  processedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

// ─────────────────────────────────────────
// TRANSACTIONS (Ledger)
// ─────────────────────────────────────────

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  status        TransactionStatus @default(COMPLETED)
  amount        Decimal           @db.Decimal(10, 2)
  balanceBefore Decimal           @db.Decimal(10, 2)
  balanceAfter  Decimal           @db.Decimal(10, 2)
  description   String?
  referenceId   String? // adWatchId or withdrawalId
  createdAt     DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─────────────────────────────────────────
// REFERRAL SYSTEM
// ─────────────────────────────────────────

model Referral {
  id             String   @id @default(uuid())
  referredById   String
  referredUserId String   @unique
  bonusAmount    Decimal  @default(0.00) @db.Decimal(10, 2)
  isPaid         Boolean  @default(false)
  createdAt      DateTime @default(now())

  referredBy   User @relation("ReferredBy", fields: [referredById], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])

  @@map("referrals")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json? // Extra data (withdrawal id etc)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────
// BLOG (For AdSense)
// ─────────────────────────────────────────

model BlogPost {
  id          String    @id @default(uuid())
  title       String
  content     String    @db.Text
  excerpt     String?
  slug        String    @unique
  coverImage  String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdBy   String // Owner/Admin id
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─────────────────────────────────────────
// APP SETTINGS (Owner controls everything)
// ─────────────────────────────────────────

model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedBy   String? // Owner id
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

// Default settings keys:
// reward_per_ad_basic      → "0.50"
// reward_per_ad_premium    → "1.00"
// daily_limit_basic        → "5"
// daily_limit_premium      → "50"
// min_withdrawal_basic     → "100"
// min_withdrawal_premium   → "50"
// referral_bonus           → "10"
// maintenance_mode         → "false"
// app_version              → "1.0.0"
// force_update             → "false"

// ─────────────────────────────────────────
// REVENUE TRACKING (Owner dashboard)
// ─────────────────────────────────────────

model RevenueRecord {
  id             String   @id @default(uuid())
  date           DateTime @unique @db.Date
  admobRevenue   Decimal  @default(0.00) @db.Decimal(12, 2)
  adsenseRevenue Decimal  @default(0.00) @db.Decimal(12, 2)
  unityRevenue   Decimal  @default(0.00) @db.Decimal(12, 2)
  otherRevenue   Decimal  @default(0.00) @db.Decimal(12, 2)
  totalRevenue   Decimal  @default(0.00) @db.Decimal(12, 2)
  totalPaidOut   Decimal  @default(0.00) @db.Decimal(12, 2)
  profit         Decimal  @default(0.00) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("revenue_records")
}

// ─────────────────────────────────────────
// BONUS / PROMO SYSTEM
// ─────────────────────────────────────────

model Bonus {
  id        String    @id @default(uuid())
  userId    String
  amount    Decimal   @db.Decimal(10, 2)
  reason    String // "welcome_bonus", "referral", "promo" etc
  isApplied Boolean   @default(false)
  appliedAt DateTime?
  createdBy String // Owner/Admin id
  createdAt DateTime  @default(now())

  @@map("bonuses")
}
