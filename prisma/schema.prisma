generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED // Temporary hold — admin/compliance review, can be reactivated
  BLOCKED // AML/fraud flag — restricted but reversible
  BANNED // Permanent — ToS violation, fraud confirmed, irreversible
  DEACTIVATED // User-initiated (self-closed account, can request reactivation)
  CLOSED // Account permanently closed (KYC fail repeatedly, or user requested deletion)
  DORMANT // No activity for X months — limited access until re-verify
}

enum LoginMethod {
  PASSWORD
  GOOGLE
  APPLE
  FACEBOOK
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  WINDOWS
  MACOS
  LINUX
}

enum KycTier {
  TIER_0 // Email/phone only — low limits
  TIER_1 // Gov ID submitted
  TIER_2 // Liveness check passed
  TIER_3 // Proof of address — full feature unlock
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_ACTION
}

enum AccountType {
  MAIN
  SAVINGS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum TransactionType {
  P2P_TRANSFER // User-to-user
  EXTERNAL_TRANSFER // To/from external bank
  SAVINGS_DEPOSIT
  SAVINGS_WITHDRAWAL
  PROMISE_PAYMENT
  BIRTHDAY_GIFT
  CARD_PAYMENT
  REFUND
  CREDIT_DISBURSEMENT
  CREDIT_REPAYMENT
}

enum PromiseFrequency {
  WEEKLY
  MONTHLY
  ONE_TIME
}

enum PromiseStatus {
  PENDING_ACCEPTANCE
  ACTIVE
  COMPLETED
  CANCELLED
  MISSED
}

enum PostVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum NotificationType {
  BIRTHDAY_REMINDER // 7d, 3d, 1d before
  BIRTHDAY_GIFT_SENT
  BIRTHDAY_GIFT_RECEIVED
  PROMISE_CREATED
  PROMISE_ACCEPTED
  PROMISE_FULFILLED
  PROMISE_MISSED
  PROMISE_REMINDER
  MONEY_RECEIVED
  MONEY_SENT
  MONEY_REQUESTED
  TAGGED_IN_POST
  TAGGED_IN_TRANSFER
  WALL_LIKE
  WALL_COMMENT
  KYC_APPROVED
  KYC_REJECTED
  CARD_FROZEN
  LOW_BALANCE
  BADGE_EARNED
  STREAK_MILESTONE
  SYSTEM
}

enum CardStatus {
  ACTIVE
  FROZEN
  BLOCKED
  EXPIRED
}

enum CardType {
  VIRTUAL
  PHYSICAL
}

enum CreditStatus {
  PENDING
  APPROVED
  ACTIVE
  PAID_OFF
  DEFAULTED
}

enum BadgeCategory {
  SAVING
  SOCIAL
  FINANCIAL_LITERACY
  GENEROSITY
  STREAK
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum AmlCheckStatus {
  CLEAR
  FLAGGED
  REVIEW_REQUIRED
  BLOCKED
}

enum AdminRole {
  SUPER_ADMIN
  COMPLIANCE_OFFICER
  SUPPORT_AGENT
  FINANCE_MANAGER
}

model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Back-relations — required by Prisma since other models reference Admin
  kycRecords         KycRecord[]
  amlChecks          AmlCheck[]
  creditApplications CreditApplication[]
  appSettings        AppSetting[]
  auditLogs          AdminAuditLog[]
  users              User[]

  @@map("admins")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id])
  action     String // e.g. "KYC_APPROVED", "USER_SUSPENDED", "SETTING_UPDATED"
  targetType String? // "User" | "Transaction" | "AppSetting"
  targetId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@map("admin_audit_logs")
}

// ─────────────────────────────────────────────
// USER & IDENTITY
// ─────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  handle            String     @unique
  phone             String     @unique
  email             String     @unique
  passwordHash      String
  dateOfBirth       DateTime
  fullName          String
  avatarUrl         String?
  bio               String?
  vybeScore         Int        @default(0)
  kyc_tier          KycTier    @default(TIER_0)
  status            UserStatus @default(PENDING_VERIFICATION)
  statusReason      String? // Why suspended/blocked/banned — audit trail
  statusChangedAt   DateTime?
  statusChangedById String? // Admin who changed it
  admin             Admin?     @relation(fields: [statusChangedById], references: [id])
  isVerified        Boolean    @default(false)

  lastLoginAt   DateTime?
  lastIpAddress String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts              Account[]
  cards                 Card[]
  kycRecords            KycRecord[]
  sentTransactions      Transaction[]       @relation("SenderTransactions")
  receivedTransactions  Transaction[]       @relation("ReceiverTransactions")
  sentRequests          PaymentRequest[]    @relation("SentRequests")
  receivedRequests      PaymentRequest[]    @relation("ReceivedRequests")
  savingsGoals          SavingsGoal[]
  promisesAsPromisor    Promise[]           @relation("PromisorPromises")
  promisesAsPromisee    Promise[]           @relation("PromiseePromises")
  posts                 Post[]
  comments              Comment[]
  likes                 Like[]
  notificationsReceived Notification[]      @relation("ReceivedNotifications")
  notificationsSent     Notification[]      @relation("SentNotifications")
  sentFriendships       Friendship[]        @relation("SentFriendships")
  receivedFriendships   Friendship[]        @relation("ReceivedFriendships")
  vybeWishSettings      VybeWishSettings?
  badges                UserBadge[]
  streaks               UserStreak[]
  creditApplications    CreditApplication[]
  auditLogs             AuditLog[]
  sessions              Session[]
  deviceTokens          DeviceToken[]
  privacySettings       PrivacySettings?
  amlChecks             AmlCheck[]

  @@map("users")
}

model Session {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  deviceId   String?
  deviceName String?
  platform   DevicePlatform?

  ipAddress String?
  userAgent String?

  loginMethod LoginMethod @default(PASSWORD)

  refreshTokenId   String @unique @default(uuid())
  refreshTokenHash String @db.VarChar(255)

  isTrusted Boolean @default(false)

  expiresAt  DateTime
  lastUsedAt DateTime?

  revokedAt     DateTime?
  revokedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, revokedAt])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique // FCM/APNs push token
  platform  String // ios | android | web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("device_tokens")
}

// ─────────────────────────────────────────────
// KYC & COMPLIANCE
// ─────────────────────────────────────────────

model KycRecord {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  tier                KycTier
  status              KycStatus @default(PENDING)
  providerRef         String?
  documentType        String?
  documentImageUrl    String?
  selfieImageUrl      String?
  livenessCheckPassed Boolean?
  proofOfAddressUrl   String?
  rejectionReason     String?
  reviewedAt          DateTime?
  admin               Admin?    @relation(fields: [adminId], references: [id])
  adminId             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("kyc_records")
}

model AmlCheck {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  transactionId String?
  transaction   Transaction?   @relation(fields: [transactionId], references: [id])
  status        AmlCheckStatus @default(CLEAR)
  reason        String?
  admin         Admin?         @relation(fields: [adminId], references: [id])
  adminId       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("aml_checks")
}

model TransactionLimit {
  id            String  @id @default(uuid())
  kyc_tier      KycTier @unique
  dailyLimit    Decimal @db.Decimal(18, 2)
  weeklyLimit   Decimal @db.Decimal(18, 2)
  monthlyLimit  Decimal @db.Decimal(18, 2)
  singleTxLimit Decimal @db.Decimal(18, 2)
  currency      String  @default("USD")

  @@map("transaction_limits")
}

// ─────────────────────────────────────────────
// ACCOUNTS & CARDS
// ─────────────────────────────────────────────

model Account {
  id                   String      @id @default(uuid())
  userId               String
  user                 User        @relation(fields: [userId], references: [id])
  virtualAccountNumber String      @unique
  balance              Decimal     @default(0) @db.Decimal(18, 2)
  currency             String      @default("USD")
  accountType          AccountType @default(MAIN)
  isActive             Boolean     @default(true)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  // Relations
  sentTransactions     Transaction[] @relation("FromAccount")
  receivedTransactions Transaction[] @relation("ToAccount")
  savingsGoal          SavingsGoal? // Only for SAVINGS accounts
  cards                Card[]

  @@map("accounts")
}

model Card {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  accountId      String
  account        Account    @relation(fields: [accountId], references: [id])
  cardType       CardType   @default(VIRTUAL)
  lastFourDigits String
  expiryMonth    Int
  expiryYear     Int
  status         CardStatus @default(ACTIVE)
  billingAddress String? // JSON string for physical cards
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("cards")
}

// ─────────────────────────────────────────────
// TRANSACTIONS & PAYMENT REQUESTS
// ─────────────────────────────────────────────

model Transaction {
  id            String            @id @default(uuid())
  fromAccountId String
  fromAccount   Account           @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccountId   String
  toAccount     Account           @relation("ToAccount", fields: [toAccountId], references: [id])
  senderId      String
  sender        User              @relation("SenderTransactions", fields: [senderId], references: [id])
  receiverId    String
  receiver      User              @relation("ReceiverTransactions", fields: [receiverId], references: [id])
  amount        Decimal           @db.Decimal(18, 2)
  currency      String            @default("USD")
  status        TransactionStatus @default(PENDING)
  type          TransactionType
  note          String? // User-written message/emoji
  reference     String            @unique // Internal idempotency key
  externalRef   String? // BaaS provider reference (Unit/Synctera)
  postToWall    Boolean           @default(false)
  hideAmount    Boolean           @default(false) // Privacy — show activity but hide amount
  promiseId     String? // If this tx fulfils a VybePromise
  promise       Promise?          @relation(fields: [promiseId], references: [id])
  socialPostId  String?           @unique
  socialPost    Post?             @relation(fields: [socialPostId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  amlChecks AmlCheck[]
  auditLogs AuditLog[]

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("transactions")
}

model PaymentRequest {
  id          String            @id @default(uuid())
  requesterId String
  requester   User              @relation("SentRequests", fields: [requesterId], references: [id])
  targetId    String
  target      User              @relation("ReceivedRequests", fields: [targetId], references: [id])
  amount      Decimal           @db.Decimal(18, 2)
  currency    String            @default("USD")
  note        String?
  status      TransactionStatus @default(PENDING)
  linkToken   String            @unique // Shareable payment link token
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("payment_requests")
}

// ─────────────────────────────────────────────
// SAVINGS GOALS
// ─────────────────────────────────────────────

model SavingsGoal {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  accountId     String    @unique
  account       Account   @relation(fields: [accountId], references: [id])
  title         String // e.g., "New iPhone", "Holiday Trip"
  targetAmount  Decimal   @db.Decimal(18, 2)
  currentAmount Decimal   @default(0) @db.Decimal(18, 2)
  currency      String    @default("USD")
  emoji         String? // Fun visual for Gen Z UX
  coverImageUrl String?
  isPublic      Boolean   @default(false) // Social sharing
  isGroupGoal   Boolean   @default(false)
  targetDate    DateTime?
  isCompleted   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  groupMembers SavingsGoalMember[]

  @@map("savings_goals")
}

model SavingsGoalMember {
  id            String      @id @default(uuid())
  savingsGoalId String
  savingsGoal   SavingsGoal @relation(fields: [savingsGoalId], references: [id])
  userId        String
  contribution  Decimal     @default(0) @db.Decimal(18, 2)
  joinedAt      DateTime    @default(now())

  @@unique([savingsGoalId, userId])
  @@map("savings_goal_members")
}

// ─────────────────────────────────────────────
// VYBEWISH — BIRTHDAY ENGINE
// ─────────────────────────────────────────────

model VybeWishSettings {
  id                       String  @id @default(uuid())
  userId                   String  @unique
  user                     User    @relation(fields: [userId], references: [id])
  isOptedIn                Boolean @default(true) // Receive birthday notifications from contacts
  showOnWall               Boolean @default(true) // Post birthday gift activity to Wall
  notifyContactsDaysBefore Int[]   @default([7, 3, 1]) // Days-before reminder schedule

  @@map("vybe_wish_settings")
}

model BirthdayNotificationJob {
  id             String    @id @default(uuid())
  birthdayUserId String // Whose birthday it is
  notifyUserId   String // Who to notify
  scheduledFor   DateTime // When to send the push notification
  daysBefore     Int // 7, 3, or 1
  isSent         Boolean   @default(false)
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  @@unique([birthdayUserId, notifyUserId, daysBefore])
  @@index([scheduledFor, isSent])
  @@map("birthday_notification_jobs")
}

// ─────────────────────────────────────────────
// VYBEPROMISE — STANDING ORDERS & COMMITMENTS
// ─────────────────────────────────────────────

model Promise {
  id                String           @id @default(uuid())
  promisorUserId    String
  promisor          User             @relation("PromisorPromises", fields: [promisorUserId], references: [id])
  promiseeUserId    String
  promisee          User             @relation("PromiseePromises", fields: [promiseeUserId], references: [id])
  title             String? // e.g., "Monthly Allowance"
  totalAmount       Decimal          @db.Decimal(18, 2)
  installmentAmount Decimal          @db.Decimal(18, 2)
  currency          String           @default("USD")
  frequency         PromiseFrequency
  totalInstallments Int // e.g., 12 for 12 months
  fulfilledCount    Int              @default(0)
  status            PromiseStatus    @default(PENDING_ACCEPTANCE)
  nextDueDate       DateTime?
  startDate         DateTime?
  endDate           DateTime?
  note              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  installments PromiseInstallment[]
  transactions Transaction[]

  @@map("promises")
}

model PromiseInstallment {
  id            String        @id @default(uuid())
  promiseId     String
  promise       Promise       @relation(fields: [promiseId], references: [id])
  installmentNo Int // 1, 2, 3... up to totalInstallments
  dueDate       DateTime
  paidAt        DateTime?
  status        PromiseStatus @default(PENDING_ACCEPTANCE)
  transactionId String? // Linked tx once fulfilled
  createdAt     DateTime      @default(now())

  @@unique([promiseId, installmentNo])
  @@map("promise_installments")
}

// ─────────────────────────────────────────────
// SOCIAL — WALL, POSTS, TAGS, LIKES, COMMENTS
// ─────────────────────────────────────────────

model Post {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  content       String?
  mediaUrls     String[] // Images/stickers attached to post
  visibility    PostVisibility @default(FRIENDS)
  isPinned      Boolean        @default(false)
  isSystemPost  Boolean        @default(false) // Auto-generated (e.g., birthday gift celebration)
  transactionId String?        @unique // Linked transaction (if financial post)
  transaction   Transaction?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  likes    Like[]
  comments Comment[]
  tags     PostTag[]

  @@index([userId, createdAt])
  @@map("posts")
}

model PostTag {
  id           String   @id @default(uuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  taggedUserId String // The @mentioned user
  createdAt    DateTime @default(now())

  @@unique([postId, taggedUserId])
  @@map("post_tags")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("likes")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

// ─────────────────────────────────────────────
// FRIENDSHIPS / SOCIAL GRAPH
// ─────────────────────────────────────────────

model Friendship {
  id         String           @id @default(uuid())
  senderId   String
  sender     User             @relation("SentFriendships", fields: [senderId], references: [id])
  receiverId String
  receiver   User             @relation("ReceivedFriendships", fields: [receiverId], references: [id])
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([senderId, receiverId])
  @@map("friendships")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id         String           @id @default(uuid())
  receiverId String
  receiver   User             @relation("ReceivedNotifications", fields: [receiverId], references: [id])
  senderId   String?
  sender     User?            @relation("SentNotifications", fields: [senderId], references: [id])
  type       NotificationType
  title      String // e.g., "@alex just sent you birthday vibes + $20!"
  body       String?
  metadata   Json? // Extra context: transactionId, postId, promiseId etc.
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([receiverId, isRead, createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// CREDIT PRODUCTS
// ─────────────────────────────────────────────
model CreditApplication {
  id                   String       @id @default(uuid())
  userId               String
  user                 User         @relation(fields: [userId], references: [id])
  requestedAmount      Decimal      @db.Decimal(18, 2)
  currency             String       @default("USD")
  creditType           String
  status               CreditStatus @default(PENDING)
  approvedAmount       Decimal?     @db.Decimal(18, 2)
  interestRate         Decimal?     @db.Decimal(5, 4)
  repaymentPeriodDays  Int?
  alternativeScoreData Json?
  consentGiven         Boolean      @default(false)
  admin                Admin?       @relation(fields: [adminId], references: [id])
  adminId              String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  credit Credit?

  @@map("credit_applications")
}

model Credit {
  id                 String            @id @default(uuid())
  applicationId      String            @unique
  application        CreditApplication @relation(fields: [applicationId], references: [id])
  principalAmount    Decimal           @db.Decimal(18, 2)
  outstandingBalance Decimal           @db.Decimal(18, 2)
  interestRate       Decimal           @db.Decimal(5, 4)
  status             CreditStatus      @default(ACTIVE)
  disbursedAt        DateTime?
  dueDate            DateTime?
  paidOffAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("credits")
}

// ─────────────────────────────────────────────
// GAMIFICATION — BADGES & STREAKS
// ─────────────────────────────────────────────

model Badge {
  id          String        @id @default(uuid())
  name        String        @unique // e.g., "Savings Streak 7 Days"
  description String
  iconUrl     String
  category    BadgeCategory
  condition   Json // Rule definition for automatic awarding

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  streakType     String // SAVING | SOCIAL | FINANCIAL_LITERACY
  currentCount   Int       @default(0)
  longestCount   Int       @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, streakType])
  @@map("user_streaks")
}

// ─────────────────────────────────────────────
// PRIVACY SETTINGS
// ─────────────────────────────────────────────

model PrivacySettings {
  id                     String         @id @default(uuid())
  userId                 String         @unique
  user                   User           @relation(fields: [userId], references: [id])
  defaultPostVisibility  PostVisibility @default(FRIENDS)
  showTransactionsOnWall Boolean        @default(true)
  showAmountsOnWall      Boolean        @default(false) // Hide $ amounts in social posts
  allowTagging           Boolean        @default(true)
  allowFriendRequests    Boolean        @default(true)
  showBirthdayToFriends  Boolean        @default(true)
  showVybeScore          Boolean        @default(true)
  updatedAt              DateTime       @updatedAt

  @@map("privacy_settings")
}

// ─────────────────────────────────────────────
// AUDIT & COMPLIANCE LOGGING
// ─────────────────────────────────────────────

model AuditLog {
  id            String       @id @default(uuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id])
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  action        String // e.g., "TRANSFER_INITIATED", "KYC_SUBMITTED", "CARD_FROZEN"
  ipAddress     String?
  userAgent     String?
  metadata      Json? // Any extra audit context
  createdAt     DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// APP SETTINGS (Owner controls everything)
// ─────────────────────────────────────────

model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  admin       Admin?   @relation(fields: [adminId], references: [id])
  adminId     String?
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

// ─────────────────────────────────────────
// REVENUE TRACKING (Owner dashboard)
// ─────────────────────────────────────────

model RevenueRecord {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date

  transactionFeeRevenue  Decimal @default(0.00) @db.Decimal(14, 2) // P2P/external transfer fees
  cardInterchangeRevenue Decimal @default(0.00) @db.Decimal(14, 2) // Card swipe/interchange fees
  interestRevenue        Decimal @default(0.00) @db.Decimal(14, 2) // Interest earned from Credit/loans
  lateFeeRevenue         Decimal @default(0.00) @db.Decimal(14, 2) // Missed promise/loan late fees
  subscriptionRevenue    Decimal @default(0.00) @db.Decimal(14, 2) // Premium tier subscriptions
  otherRevenue           Decimal @default(0.00) @db.Decimal(14, 2)

  totalRevenue Decimal @default(0.00) @db.Decimal(14, 2)
  totalPayouts Decimal @default(0.00) @db.Decimal(14, 2) // Referral bonuses, promotions, refunds paid out
  netProfit    Decimal @default(0.00) @db.Decimal(14, 2)

  currency  String   @default("USD")
